# ================================
# OS / System Files
# ================================
# Windows junk
Thumbs.db
Desktop.ini
ehthumbs.db
[Dd]esktop.ini
$RECYCLE.BIN/

# macOS junk
.DS_Store
.AppleDouble
.LSOverride
__MACOSX/

# ================================
# Editors & IDEs
# ================================
# VS Code
.vscode/
.history/
*.code-workspace

# JetBrains Rider/IDEA
.idea/

# Backup / temp files
*~
*.bak
*.tmp
*.swp
*.swo

# ================================
# PowerShell Specific
# ================================
# PowerShell script backups
*.ps1~
*.psm1~
*.psd1~

# PowerShell transcript logs
PowerShell_transcript*.*

# Build output (if packaging modules)
bin/
obj/
out/
release/
build/

# ================================
# Logs & Reports
# ================================
*.log
*.evtx
*.etl
*.trace
*.dmp

# ================================
# Dependencies / Binaries
# ================================
# Ignore compiled DLLs, EXEs, etc. (if you later build modules)
*.dll
*.exe

# ================================
# OneDrive / Sync Artifacts
# ================================
*.lnk
*.tmp
~$*
*.lock
*.sync
*.gsync

# ================================
# CSV & Data Handling
# ================================
# Ignore temp CSV exports (unless intentionally committed)
*.csv.tmp
*.csv.bak
~$*.csv

# DO NOT ignore CSVs in inputs/ (these are part of automation)
!inputs/*.csv

# ================================
# Documentation
# ================================
# Office temp files
~$*.doc*
~$*.xls*
~$*.ppt*

# Ignore exported reports unless saved in docs/
reports/
*.pdf

# ================================
# Git
# ================================
# Ignore Git merge/patch leftovers
*.orig
*.rej
*.patch
*.diff